{
  acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  auto_https disable_redirects
}


http://*.{{ .Values.ingressDomain }}, *.{{ .Values.ingressDomain }} {
  log
  tls {
    dns cloudflare {env.CLOUDFLARE_API_TOKEN}
  }

  @ldap host {{ .Values.subdomainPrefix }}ldap.{{ .Values.ingressDomain }}
  handle @ldap {
    reverse_proxy lldap.{{ .Values.infraNamespace }}.svc.cluster.local:17170
  }

  @nas host {{ .Values.subdomainPrefix }}nas.{{ .Values.ingressDomain }}
  handle @nas {
    reverse_proxy {env.NAS_TARGET}
  }

  @tv host {{ .Values.subdomainPrefix }}tv.{{ .Values.ingressDomain }}
  handle @tv {
    reverse_proxy stream-share.{{ .Values.infraNamespace }}.svc.cluster.local:8080
  }

  @status host {{ .Values.subdomainPrefix }}status.{{ .Values.ingressDomain }}
  handle @status {
    reverse_proxy gatus.{{ .Values.infraNamespace }}.svc.cluster.local:8080
  }

  @vault host {{ .Values.subdomainPrefix }}vault.{{ .Values.ingressDomain }}
  handle @vault {
    reverse_proxy vaultwarden.{{ .Values.infraNamespace }}.svc.cluster.local:80 {
      header_up X-Real-IP {remote_host}
    }
  }

  @vault-ws {
    host {{ .Values.subdomainPrefix }}vault.{{ .Values.ingressDomain }}
    path /notifications/hub*
  }
  handle @vault-ws {
    reverse_proxy vaultwarden.{{ .Values.infraNamespace }}.svc.cluster.local:3012
  }

  @suivi host {{ .Values.subdomainPrefix }}suivi.{{ .Values.ingressDomain }}
  handle @suivi {
    reverse_proxy suivi-item.{{ .Values.suiviItemNamespace }}.svc.cluster.local:80
  }

  @resume host {{ .Values.subdomainPrefix }}resume.{{ .Values.ingressDomain }}
  handle @resume {
    redir https://portfolio.lucasduport.cc/cvs/CV_EN_2025.pdf
  }

  @cv host {{ .Values.subdomainPrefix }}cv.{{ .Values.ingressDomain }}
  handle @cv {
    redir https://portfolio.lucasduport.cc/cvs/CV_FR_2025.pdf
  }

  @lkdn host {{ .Values.subdomainPrefix }}lkdn.{{ .Values.ingressDomain }}
  handle @lkdn {
    redir https://www.linkedin.com/in/lucas-duport/
  }

  @www host {{ .Values.subdomainPrefix }}www.{{ .Values.ingressDomain }}
  handle @www {
    redir https://{{ .Values.ingressDomain }}{uri}
  }

  handle {
    {{- if .Values.isDev }}
    respond "404 Not Found (Dev Kubernetes Caddy)" 404
    {{- else }}
    respond "404 Not Found (Production Kubernetes Caddy)" 404
    {{- end }}
  }
}

{{ .Values.ingressDomain }} {
  redir https://portfolio.lucasduport.cc{uri}
}
